#############################
# VIRTUAL ENVIRONMENT
#############################
# The Python environment folder (venv) is ignored
# because it is different for each machine.
venv/
approx/

# Environment files containing sensitive keys (secret keys, passwords, etc.)
.env
.env.*
*.env


#############################
# CACHE & PYTHON FILES
#############################
# Files automatically compiled by Python
__pycache__/
*.pyc
*.pyo
*.pyd


#############################
# DJANGO & WAGTAIL
#############################
# Local SQLite database.
# It contains development data, which is different for each user.
db.sqlite3

# Files uploaded via Wagtail (images, media) – never versioned.
media/

# Static files collected with "collectstatic".
# They can be regenerated and should not be pushed.
staticfiles/

# Non-versioned local settings (often used in development)
local_settings.py


#############################
# LOGS
#############################
# Log files generated by Django
*.log


#############################
# IDE & CODE EDITORS
#############################
# File VS Code
.vscode/

# PyCharm / IntelliJ folder (macOS + other OS)
.idea/

# JetBrains Files
*.iml

# Notebook files
.ipynb_checkpoints/


#############################
# SYSTEM / OS
#############################
# Files generated by macOS
.DS_Store
.AppleDouble
.LSOverride

# Files generated by Windows
Thumbs.db
ehthumbs.db

# macOS Trash
.Trashes